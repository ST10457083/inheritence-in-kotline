open class Person(
    var firstName: String,
    var lastName: String
) {
    open fun getName(): String {
        return "$firstName $lastName"
    }
}

class Employee(
    firstName: String,
    lastName: String,
    var employeeId: Int,
    var department: String
) : Person(firstName, lastName) {

    // Override method from Person
    override fun getName(): String {
        return "Employee: ${super.getName()}"
    }
}

fun main() {
    val emp = Employee("Moshito", "Petja", 101, "IT")

    println("Name: ${emp.getName()}")
    println("Employee ID: ${emp.employeeId}")
    println("Department: ${emp.department}")
}
